{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ramirezh84/failoverv2/profiles/profile.schema.json",
  "title": "Per-app failover orchestrator profile",
  "description": "Schema for the per-app YAML profile that drives all orchestrator behavior. The orchestrator's runtime is profile-driven; no code change is required to onboard a new app. See SPEC.md §7.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app_name",
    "pattern",
    "primary_region",
    "secondary_region",
    "components",
    "network",
    "dns",
    "kafka",
    "signals",
    "canary",
    "failover",
    "slo",
    "notifications"
  ],
  "properties": {
    "app_name": {
      "type": "string",
      "description": "DNS-safe app slug, used as a key in resource ARNs and SNS message attributes.",
      "pattern": "^[a-z][a-z0-9-]{2,62}$",
      "minLength": 3,
      "maxLength": 63
    },
    "pattern": {
      "type": "string",
      "description": "Failover pattern. The POC currently exercises active_passive only; active_active is reserved for future read-mostly apps.",
      "enum": ["active_passive", "active_active"]
    },
    "primary_region": {
      "type": "string",
      "description": "AWS region where the application normally runs.",
      "enum": ["us-east-1", "us-east-2"]
    },
    "secondary_region": {
      "type": "string",
      "description": "AWS region the app fails over to. Must differ from primary_region.",
      "enum": ["us-east-1", "us-east-2"]
    },
    "components": {
      "type": "object",
      "description": "Which optional components the app uses. Decision Engine and Executor only collect/act on signals for components the app declares.",
      "additionalProperties": false,
      "required": ["api_gateway", "aurora", "elasticache", "kafka_consumer"],
      "properties": {
        "api_gateway": { "type": "boolean", "description": "App fronts traffic through API Gateway." },
        "aurora": { "type": "boolean", "description": "App uses Aurora Global." },
        "elasticache": { "type": "boolean", "description": "App uses ElastiCache Global Datastore." },
        "kafka_consumer": { "type": "boolean", "description": "App has a Kafka consumer gated on the regional indicator." }
      }
    },
    "network": {
      "type": "object",
      "description": "ARNs and IDs of the app's network fabric in both regions. SPEC §7.",
      "additionalProperties": false,
      "required": [
        "outer_nlb_arn_primary",
        "outer_nlb_arn_secondary",
        "alb_arn_primary",
        "alb_arn_secondary",
        "routable_url_primary",
        "routable_url_secondary"
      ],
      "properties": {
        "outer_nlb_arn_primary": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:" },
        "outer_nlb_arn_secondary": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:" },
        "alb_arn_primary": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:" },
        "alb_arn_secondary": { "type": "string", "pattern": "^arn:aws:elasticloadbalancing:" },
        "api_gw_id_primary": { "type": ["string", "null"], "description": "Required iff components.api_gateway=true.", "pattern": "^[a-z0-9]{8,}$" },
        "api_gw_id_secondary": { "type": ["string", "null"], "pattern": "^[a-z0-9]{8,}$" },
        "routable_url_primary": { "type": "string", "format": "uri", "pattern": "^https://" },
        "routable_url_secondary": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "dns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["global_record_name", "hosted_zone_id"],
      "properties": {
        "global_record_name": { "type": "string", "description": "The R53 record that the orchestrator flips between regional health checks.", "minLength": 4 },
        "hosted_zone_id": { "type": "string", "description": "Route 53 hosted zone ID owning global_record_name.", "pattern": "^Z[A-Z0-9]{1,32}$" }
      }
    },
    "aurora": {
      "type": ["object", "null"],
      "description": "Required iff components.aurora=true.",
      "additionalProperties": false,
      "required": [
        "cluster_id_primary",
        "cluster_id_secondary",
        "global_cluster_id",
        "writer_policy",
        "manual_approval_required",
        "aurora_confirm_timeout_minutes",
        "dns_first_failover"
      ],
      "properties": {
        "cluster_id_primary": { "type": "string", "minLength": 1 },
        "cluster_id_secondary": { "type": "string", "minLength": 1 },
        "global_cluster_id": { "type": "string", "minLength": 1 },
        "writer_policy": { "type": "string", "enum": ["pin_primary", "follow_traffic"] },
        "manual_approval_required": {
          "type": "boolean",
          "description": "When true, executor pauses at the Aurora gate via .waitForTaskToken until SendTaskSuccess. Default true (SPEC §4.3)."
        },
        "aurora_confirm_timeout_minutes": { "type": "integer", "minimum": 1, "maximum": 240, "description": "Default 30 (SPEC §5.1)." },
        "dns_first_failover": { "type": "boolean", "description": "When true (default), DNS flips before writer promotion (SPEC §5.1)." }
      }
    },
    "elasticache": {
      "type": ["object", "null"],
      "description": "Required iff components.elasticache=true.",
      "additionalProperties": false,
      "properties": {
        "global_replication_group_id": { "type": "string", "minLength": 1 },
        "auto_failover": { "type": "boolean", "default": false }
      },
      "required": ["global_replication_group_id"]
    },
    "kafka": {
      "type": "object",
      "additionalProperties": false,
      "required": ["consumer_group", "gate_on_indicator"],
      "properties": {
        "consumer_group": { "type": "string", "minLength": 1 },
        "gate_on_indicator": { "type": "boolean", "description": "When true, the app library pauses the consumer based on /failover/{app}/{region}/role." }
      }
    },
    "signals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tier1_quorum", "dwell_minutes", "hysteresis_minutes", "canary_failure_rate_pct"],
      "properties": {
        "tier1_quorum": { "type": "integer", "minimum": 1, "maximum": 10, "description": "Number of distinct Tier 1 signals that must be red simultaneously. Default 2 (SPEC §4.3)." },
        "dwell_minutes": { "type": "integer", "minimum": 1, "maximum": 60, "description": "Continuous duration the quorum must hold. Default 5." },
        "hysteresis_minutes": { "type": "integer", "minimum": 0, "maximum": 60, "description": "Minimum time between successive decision changes. Default 3." },
        "canary_failure_rate_pct": { "type": "integer", "minimum": 1, "maximum": 100, "description": "Failure rate (%) over the dwell window that turns the canary signal red. Default 80." }
      }
    },
    "canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ignore_tls_errors", "internal_ca_bundle_s3_uri"],
      "properties": {
        "ignore_tls_errors": { "type": "boolean", "description": "Synthetics canary Puppeteer flag. true for POC (self-signed); false for JPMC (SPEC §2.1 POC-A)." },
        "internal_ca_bundle_s3_uri": { "type": ["string", "null"], "pattern": "^s3://[a-z0-9.-]{3,63}/.+$" }
      }
    },
    "failover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auto_failover",
        "auto_failback",
        "drain_seconds",
        "quiesce_seconds",
        "r53_propagation_seconds",
        "stable_minutes_before_failback"
      ],
      "properties": {
        "auto_failover": { "type": "boolean", "description": "When false (default for first 30 days), Decision Engine emits SNS only — operator triggers failover manually. SPEC §4.3." },
        "auto_failback": { "type": "boolean", "description": "Always false; failback is always operator-triggered. Hard constraint (CLAUDE.md §2 #9)." },
        "drain_seconds": { "type": "integer", "minimum": 10, "maximum": 600, "description": "How long the executor waits after writing DRAINING before flipping R53/indicator. Default 60." },
        "quiesce_seconds": { "type": "integer", "minimum": 10, "maximum": 600, "description": "How long the executor waits for in-flight requests to complete during failback. Default 60." },
        "r53_propagation_seconds": { "type": "integer", "minimum": 30, "maximum": 600, "description": "How long the executor waits after flipping the R53 control metric. Default 90." },
        "stable_minutes_before_failback": { "type": "integer", "minimum": 5, "maximum": 1440, "description": "How long primary Tier 1 signals must be green before PRECHECK_PRIMARY succeeds. Default 30." }
      }
    },
    "slo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rto_minutes", "rpo_minutes"],
      "properties": {
        "rto_minutes": { "type": "integer", "minimum": 1, "maximum": 240 },
        "rpo_minutes": { "type": "integer", "minimum": 0, "maximum": 240 }
      }
    },
    "notifications": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sns_topic_arn_primary", "sns_topic_arn_secondary", "events"],
      "properties": {
        "sns_topic_arn_primary": { "type": "string", "pattern": "^arn:aws:sns:" },
        "sns_topic_arn_secondary": { "type": "string", "pattern": "^arn:aws:sns:" },
        "events": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "failover_authorized",
              "failover_initiated",
              "failover_step_completed",
              "failover_completed",
              "failover_failed",
              "failback_initiated",
              "failback_completed",
              "failback_failed",
              "signal_red",
              "signal_recovered"
            ]
          }
        }
      }
    }
  },
  "allOf": [
    {
      "description": "secondary_region must differ from primary_region.",
      "not": { "properties": { "primary_region": { "const": "us-east-1" }, "secondary_region": { "const": "us-east-1" } } }
    },
    {
      "not": { "properties": { "primary_region": { "const": "us-east-2" }, "secondary_region": { "const": "us-east-2" } } }
    },
    {
      "description": "If components.aurora=true then aurora block must be present (object).",
      "if": { "properties": { "components": { "properties": { "aurora": { "const": true } }, "required": ["aurora"] } } },
      "then": { "properties": { "aurora": { "type": "object" } } }
    },
    {
      "description": "If components.aurora=false then aurora must be null.",
      "if": { "properties": { "components": { "properties": { "aurora": { "const": false } }, "required": ["aurora"] } } },
      "then": { "properties": { "aurora": { "type": "null" } } }
    },
    {
      "description": "If components.elasticache=true then elasticache block must be present.",
      "if": { "properties": { "components": { "properties": { "elasticache": { "const": true } }, "required": ["elasticache"] } } },
      "then": { "properties": { "elasticache": { "type": "object" } } }
    },
    {
      "description": "If components.elasticache=false then elasticache must be null.",
      "if": { "properties": { "components": { "properties": { "elasticache": { "const": false } }, "required": ["elasticache"] } } },
      "then": { "properties": { "elasticache": { "type": "null" } } }
    },
    {
      "description": "If components.api_gateway=true then api_gw_id_primary and api_gw_id_secondary must be non-null strings.",
      "if": { "properties": { "components": { "properties": { "api_gateway": { "const": true } }, "required": ["api_gateway"] } } },
      "then": {
        "properties": {
          "network": {
            "required": ["api_gw_id_primary", "api_gw_id_secondary"],
            "properties": {
              "api_gw_id_primary": { "type": "string" },
              "api_gw_id_secondary": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "description": "auto_failback must be false (CLAUDE.md §2 hard constraint #9).",
      "properties": { "failover": { "properties": { "auto_failback": { "const": false } } } }
    }
  ]
}
